{
  "name": "doro-music-scheduler",
  "version": "1.0.0",
  "description": "Automatic music scheduling agent for DORO restaurant — PRIVATE/INTERNAL USE ONLY",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "auth": "tsx src/spotify/auth-setup.ts",
    "dry-run": "cross-env DRY_RUN=true tsx src/index.ts",
    "lint": "eslint src/",
    "test": "node --test dist/**/*.test.js"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "luxon": "^3.5.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
