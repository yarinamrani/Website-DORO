# Supabase (required for web app)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Gemini API (required for invoice scanning scripts)
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Management API (required for setup-db.mjs / seed-data.mjs only)
# Get your token at: https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=sbp_your-access-token-here
